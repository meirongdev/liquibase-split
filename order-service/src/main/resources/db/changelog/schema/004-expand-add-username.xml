<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="004-expand-add-username" author="meirong">
        <preConditions onFail="MARK_RAN">
            <not>
                <columnExists tableName="orders" columnName="username"/>
            </not>
        </preConditions>

        <addColumn tableName="orders">
            <column name="username" type="VARCHAR(100)"/>
        </addColumn>
    </changeSet>

    <changeSet id="004-backfill-username-from-user-name" author="meirong">
        <preConditions onFail="MARK_RAN">
            <columnExists tableName="orders" columnName="user_name"/>
        </preConditions>

        <sql>UPDATE ${service_schema}.orders SET username = user_name WHERE username IS NULL</sql>
    </changeSet>

    <changeSet id="004-backfill-username-from-users" author="meirong">
        <preConditions onFail="MARK_RAN">
            <tableExists tableName="users"/>
        </preConditions>

        <sql>UPDATE ${service_schema}.orders o SET username = u.username FROM ${service_schema}.users u WHERE o.user_id = u.id AND o.username IS NULL</sql>
    </changeSet>

    <changeSet id="004-enforce-username-not-null" author="meirong">
        <addNotNullConstraint
            tableName="orders"
            columnName="username"
            columnDataType="VARCHAR(100)"/>
    </changeSet>
</databaseChangeLog>
